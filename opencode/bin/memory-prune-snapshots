#!/usr/bin/env bash
set -euo pipefail

SNAPSHOTS_DIR="${MEMORY_SNAPSHOTS_DIR:-$HOME/.config/opencode/memory-snapshots-local}"
DRY_RUN=false

for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=true ;;
    *) echo "Unknown argument: $arg" >&2; exit 1 ;;
  esac
done

if [[ ! -d "$SNAPSHOTS_DIR" ]]; then
  echo "Warning: snapshot directory does not exist: $SNAPSHOTS_DIR" >&2
  exit 0
fi

stale_files=()
while IFS= read -r -d '' file; do
  stale_files+=("$file")
done < <(find "$SNAPSHOTS_DIR" -maxdepth 1 -name "*.json" -mtime +30 -print0)

total_count=0
while IFS= read -r -d '' _; do
  (( total_count++ )) || true
done < <(find "$SNAPSHOTS_DIR" -maxdepth 1 -name "*.json" -print0)

pruned=0
for file in "${stale_files[@]+"${stale_files[@]}"}"; do
  if [[ "$DRY_RUN" == true ]]; then
    echo "[DRY RUN] Would delete: $file"
  else
    rm "$file"
    echo "Deleted: $file"
  fi
  (( pruned++ )) || true
done

kept=$(( total_count - pruned ))
echo "Pruned $pruned snapshots (kept $kept)"
