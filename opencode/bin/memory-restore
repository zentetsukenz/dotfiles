#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: memory-restore <snapshot-file>" >&2
  exit 1
}

if [[ $# -ne 1 ]]; then
  usage
fi

snapshot_file="$1"
memory_file="${MEMORY_FILE:-$HOME/.config/opencode/memory.json}"
snapshots_dir="${MEMORY_SNAPSHOTS_DIR:-$HOME/.config/opencode/memory-snapshots-local}"

if [[ ! -f "$snapshot_file" ]]; then
  echo "Error: snapshot file not found: ${snapshot_file}" >&2
  exit 1
fi

mkdir -p "$snapshots_dir"

safety_snapshot="${snapshots_dir}/pre-restore-$(date +%Y%m%dT%H%M%S).json"
if [[ -f "$memory_file" ]]; then
  cp "$memory_file" "$safety_snapshot"
  echo "Safety snapshot: ${safety_snapshot}"
else
  echo "No existing memory file to snapshot (fresh restore)"
fi

cp "$snapshot_file" "$memory_file"
echo "Restored: ${snapshot_file} → ${memory_file}"
