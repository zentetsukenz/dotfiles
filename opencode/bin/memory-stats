#!/usr/bin/env bash

set -euo pipefail

JQ="/opt/homebrew/bin/jq"
DEFAULT_MEMORY_FILE="${MEMORY_FILE:-$HOME/.config/opencode/memory.json}"
CAP_TOKENS=4000
WARN_TOKENS=2800  # 70% of cap

# --- Argument parsing ---
output_json=false
memory_file="$DEFAULT_MEMORY_FILE"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --json)
      output_json=true
      shift
      ;;
    --fixture)
      if [[ -z "${2:-}" ]]; then
        printf 'error: --fixture requires a path argument\n' >&2
        exit 1
      fi
      memory_file="$2"
      shift 2
      ;;
    *)
      printf 'error: unknown argument: %s\n' "$1" >&2
      exit 1
      ;;
  esac
done

# --- File check ---
if [[ ! -f "$memory_file" ]]; then
  printf 'error: memory file not found: %s\n' "$memory_file" >&2
  exit 1
fi

# --- Metrics ---
size_bytes=$(wc -c < "$memory_file" | tr -d ' ')
tokens=$(( size_bytes / 3 ))
entities=$("$JQ" -s '[.[] | select(.type == "entity")] | length' "$memory_file")
relations=$("$JQ" -s '[.[] | select(.type == "relation")] | length' "$memory_file")

# Cap status
cap_pct=$(( tokens * 100 / CAP_TOKENS ))
if (( tokens > CAP_TOKENS )); then
  cap_status="OVER"
elif (( tokens >= WARN_TOKENS )); then
  cap_status="WARN"
else
  cap_status="OK"
fi

# Top 5 entities by observation count (name + count pairs, newline-separated)
top_entities_raw=$("$JQ" -r '
  [inputs | select(.type == "entity") | {name: .name, obs_count: (.observations | length)}]
  | sort_by(-.obs_count)
  | .[0:5][]
  | "\(.name)\t\(.obs_count)"
' "$memory_file")

# --- Output ---
if $output_json; then
  # shellcheck disable=SC2016
  top_entities_json=$( "$JQ" -n \
    --argjson entities "$entities" \
    --argjson relations "$relations" \
    --argjson size_bytes "$size_bytes" \
    --argjson tokens "$tokens" \
    --arg cap_status "$cap_status" \
    --argjson cap_pct "$cap_pct" \
    --arg file "$memory_file" \
    --rawfile top_raw <(printf '%s' "$top_entities_raw") \
    '
    def parse_top:
      split("\n") | map(select(length > 0)) |
      map(split("\t") | {name: .[0], obs_count: (.[1] | tonumber)});
    {
      file: $file,
      size_bytes: $size_bytes,
      tokens: $tokens,
      cap_status: $cap_status,
      cap_pct: $cap_pct,
      entities: $entities,
      relations: $relations,
      top_entities: ($top_raw | parse_top)
    }
  ')
  printf '%s\n' "$top_entities_json"
else
  printf '=== Server-Memory Stats ===\n'
  printf 'File: %s\n' "$memory_file"
  printf 'Size: %d bytes\n' "$size_bytes"
  printf 'Tokens: ~%d (bytes/3 approximation)\n' "$tokens"
  printf 'Cap: %s (%d/%d tokens, %d%%)\n' "$cap_status" "$tokens" "$CAP_TOKENS" "$cap_pct"
  printf 'Entities: %d\n' "$entities"
  printf 'Relations: %d\n' "$relations"
  printf 'Top 5 entities by observation count:\n'
  rank=1
  while IFS=$'\t' read -r name obs_count; do
    printf '  %d. %s (%d observations)\n' "$rank" "$name" "$obs_count"
    (( rank++ )) || true
  done <<< "$top_entities_raw"
fi
