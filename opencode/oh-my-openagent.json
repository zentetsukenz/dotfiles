{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "new_task_system_enabled": true,
  "sisyphus": {
    "tasks": {
      "storage_path": ".omo/tasks",
      "claude_code_compat": false
    }
  },
  "skills": {
    "sources": [
      "~/.config/opencode/skills"
    ]
  },
  "notification": {
    "force_enable": true
  },
  "model_capabilities": {
    "enabled": true,
    "auto_refresh_on_start": true,
    "refresh_timeout_ms": 5000
  },
  "disabled_hooks": [
    "startup-toast",
    "claude-code-hooks"
  ],
  "browser_automation_engine": {
    "provider": "playwright"
  },
  "mcp_env_allowlist": [
    "PATH",
    "HOME",
    "MEMORY_FILE_PATH",
    "USER"
  ],
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 45,
    "notify_on_fallback": true
  },
  "background_task": {
    "defaultConcurrency": 8,
    "providerConcurrency": {
      "anthropic": 3,
      "openai": 3,
      "github-copilot": 5,
      "google": 5
    },
    "modelConcurrency": {
      "github-copilot/claude-opus-4.7": 2
    }
  },
  "ralph_loop": {
    "enabled": false,
    "default_max_iterations": 100,
    "default_strategy": "continue"
  },
  "auto_update": false,
  "default_run_agent": "prometheus",
  "model_fallback": true,
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "inline"
  },
  "start_work": {
    "auto_commit": true
  },
  "babysitting": {
    "timeout_ms": 300000
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true,
    "auto_resume": true,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "detailed",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "protected_tools": [
        "task",
        "todowrite"
      ],
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    },
    "preemptive_compaction": true,
    "truncate_all_tool_outputs": true
  },
  "hashline_edit": true,
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false,
    "git_env_prefix": "GIT_MASTER=1"
  },
  "agents": {
    "sisyphus": {
      "model": "github-copilot/claude-opus-4.7",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gpt-5.5",
        "github-copilot/claude-sonnet-4.6"
      ],
      "skills": [
        "caveman",
        "qa-witness-protocol",
        "to-prd",
        "to-issues",
        "tdd",
        "diagnose",
        "prototype",
        "verification-before-completion",
        "systematic-debugging"
      ],
      "ultrawork": {
        "model": "github-copilot/gpt-5.5",
        "variant": "xhigh"
      }
    },
    "sisyphus-junior": {
      "model": "github-copilot/claude-sonnet-4.6",
      "variant": "high",
      "fallback_models": [
        "github-copilot/claude-haiku-4.5",
        "github-copilot/gemini-3-flash-preview"
      ],
      "skills": [
        "caveman",
        "tdd",
        "diagnose",
        "verification-before-completion",
        "systematic-debugging"
      ]
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/claude-opus-4.6"
      ],
      "skills": [
        "caveman",
        "improve-codebase-architecture",
        "prototype"
      ]
    },
    "oracle": {
      "model": "github-copilot/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        "github-copilot/claude-opus-4.7",
        "github-copilot/claude-sonnet-4.6"
      ],
      "skills": [
        "caveman",
        "architect-review"
      ]
    },
    "librarian": {
      "model": "github-copilot/gemini-3-flash-preview",
      "fallback_models": [
        "github-copilot/claude-haiku-4.5",
        "github-copilot/gemini-3-flash-preview"
      ],
      "skills": [
        "caveman"
      ]
    },
    "explore": {
      "model": "github-copilot/claude-haiku-4.5",
      "fallback_models": [
        "github-copilot/gemini-3-flash-preview"
      ],
      "skills": [
        "caveman"
      ]
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gpt-5.5",
        "github-copilot/gemini-3-flash-preview"
      ],
      "skills": [
        "caveman"
      ]
    },
    "prometheus": {
      "model": "github-copilot/claude-opus-4.7",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gpt-5.5",
        "github-copilot/claude-sonnet-4.6"
      ],
      "skills": [
        "caveman",
        "domain-model",
        "design-an-interface",
        "triage",
        "qa-witness-protocol",
        "to-prd",
        "to-issues",
        "zoom-out",
        "skill-creator",
        "architect-review"
      ]
    },
    "metis": {
      "model": "github-copilot/claude-opus-4.7",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gpt-5.5",
        "github-copilot/claude-sonnet-4.6"
      ],
      "skills": [
        "caveman",
        "zoom-out",
        "grill-with-docs"
      ]
    },
    "momus": {
      "model": "github-copilot/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        "github-copilot/claude-opus-4.7",
        "github-copilot/claude-sonnet-4.6"
      ],
      "skills": [
        "caveman",
        "grill-with-docs"
      ]
    },
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "github-copilot/claude-haiku-4.5",
        "github-copilot/gemini-3-flash-preview"
      ],
      "skills": [
        "caveman",
        "zoom-out"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "description": "Frontend, UI/UX, design, styling, animation, CSS, layout"
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.5",
      "variant": "xhigh",
      "description": "Genuinely hard, logic-heavy tasks requiring deep reasoning"
    },
    "deep": {
      "model": "github-copilot/gpt-5.5",
      "variant": "medium",
      "description": "Goal-oriented autonomous problem-solving with thorough research"
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high",
      "description": "Complex problems requiring unconventional, creative approaches",
      "prompt_append": "\n\nFavor divergent thinking. Generate 3 radically different approaches before converging. Prefer the unconventional choice when tradeoffs are even."
    },
    "quick": {
      "model": "github-copilot/claude-haiku-4.5",
      "description": "Trivial tasks \u2014 single file changes, typo fixes, simple modifications"
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6",
      "description": "Low effort tasks that don't fit other categories"
    },
    "unspecified-high": {
      "model": "github-copilot/claude-opus-4.7",
      "description": "High effort tasks that don't fit other categories"
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview",
      "description": "Documentation, prose, technical writing",
      "prompt_append": "\n\nFor prose editing, invoke the `edit-article` skill to apply structural and stylistic improvements."
    }
  }
}
