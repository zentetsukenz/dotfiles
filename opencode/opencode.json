{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "prometheus",
  "enabled_providers": [
    "github-copilot",
    "opencode",
    "opencode-go",
    "openrouter"
  ],
  "permission": {
    "edit": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "allow",
      "/.*\\|\\s*xargs(\\s|$).*/": "ask",
      "/.*\\b(bash|sh|zsh)\\s+-c\\b.*/": "ask",
      "rm *": "ask",
      "rmdir *": "ask",
      "unlink *": "ask",
      "sudo *": "ask",
      "doas *": "ask",
      "git push --force": "ask",
      "git push --force *": "ask",
      "git push -f": "ask",
      "git push -f *": "ask",
      "git push --force-with-lease": "ask",
      "git push --force-with-lease*": "ask",
      "git push --delete *": "ask",
      "git reset --hard": "ask",
      "git reset --hard *": "ask",
      "git rebase *": "ask",
      "git filter-branch *": "ask",
      "git filter-repo *": "ask",
      "git branch -d *": "ask",
      "git branch -D *": "ask",
      "git clean -f*": "ask",
      "git clean -d*": "ask",
      "git restore --staged *": "ask",
      "git checkout -- *": "ask",
      "git checkout .": "ask",
      "git stash drop": "ask",
      "git stash drop *": "ask",
      "git stash clear": "ask",
      "git tag -d *": "ask",
      "dd *": "ask",
      "mkfs*": "ask",
      "shutdown*": "ask",
      "reboot*": "ask",
      "halt*": "ask",
      "kill -9 *": "ask",
      "killall *": "ask",
      "brew uninstall *": "ask",
      "npm uninstall *": "ask",
      "pip uninstall *": "ask",
      "mise uninstall *": "ask"
    }
  },
  "lsp": {
    "typescript-language-server": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ]
    },
    "pyright": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "ruby-lsp": {
      "command": [
        "ruby-lsp"
      ],
      "extensions": [
        ".rb",
        ".rake",
        ".gemspec",
        ".ru"
      ]
    },
    "elixir-ls": {
      "command": [
        "elixir-ls"
      ],
      "extensions": [
        ".ex",
        ".exs",
        ".eex",
        ".heex",
        ".leex",
        ".sface"
      ]
    }
  },
  "plugin": [
    "oh-my-openagent@4.2.2",
    "context-mode"
  ],
  "autoupdate": "notify",
  "share": "manual",
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd"
      ],
      "environment": {}
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "environment": {
        "MEMORY_FILE_PATH": "/Users/zentetsuken/.config/opencode/memory.json"
      }
    }
  },
  "provider": {
    "github-copilot": {
      "models": {
        "claude-opus-4.6": {
          "variants": {
            "max": {
              "disabled": true
            }
          }
        },
        "claude-sonnet-4.6": {
          "variants": {
            "max": {
              "disabled": true
            }
          }
        },
        "claude-haiku-4.5": {
          "variants": {
            "high": {
              "disabled": true
            },
            "max": {
              "disabled": true
            }
          }
        },
        "gpt-5.4": {
          "variants": {
            "none": {
              "disabled": true
            },
            "minimal": {
              "disabled": true
            },
            "low": {
              "disabled": true
            }
          }
        },
        "gpt-5.3-codex": {
          "variants": {
            "none": {
              "disabled": true
            },
            "minimal": {
              "disabled": true
            },
            "low": {
              "disabled": true
            },
            "medium": {
              "disabled": true
            },
            "high": {},
            "xhigh": {
              "disabled": true
            }
          }
        },
        "gemini-3-flash-preview": {
          "variants": {
            "low": {
              "disabled": true
            },
            "high": {
              "disabled": true
            }
          }
        },
        "gemini-3.1-pro-preview": {
          "variants": {
            "low": {
              "disabled": true
            }
          }
        },
        "gpt-4.1": {
          "disabled": true
        },
        "gpt-4o": {
          "disabled": true
        },
        "gpt-5-mini": {
          "disabled": true
        },
        "claude-opus-4.5": {
          "disabled": true
        },
        "claude-sonnet-4.5": {
          "disabled": true
        },
        "gpt-5.2": {},
        "gpt-5.2-codex": {
          "disabled": true
        },
        "claude-opus-4.7": {
          "variants": {
            "max": {
              "disabled": true
            }
          }
        }
      }
    },
    "opencode": {},
    "opencode-go": {},
    "openrouter": {}
  }
}
