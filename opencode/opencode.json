{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "prometheus",
  "permission": {
    "edit": "allow",
    "bash": "ask",
    "webfetch": "ask"
  },
  "lsp": {
    "typescript-language-server": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts"]
    },
    "pyright": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [".py", ".pyi"]
    },
    "ruby-lsp": {
      "command": [
        "ruby-lsp"
      ],
      "extensions": [".rb", ".rake", ".gemspec", ".ru"]
    },
    "elixir-ls": {
      "command": [
        "elixir-ls"
      ],
      "extensions": [".ex", ".exs", ".eex", ".heex", ".leex", ".sface"]
    }
  },
  "plugin": [
    "oh-my-openagent@latest",
    "context-mode"
  ],
  "autoupdate": "notify",
  "share": "manual",
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ]
    }
  },
  "provider": {
    "github-copilot": {
      "models": {
        "claude-opus-4.6": {
          "variants": {
            "max": {
              "disabled": true
            }
          }
        },
        "claude-sonnet-4.6": {
          "variants": {
            "max": {
              "disabled": true
            }
          }
        },
        "claude-haiku-4.5": {
          "variants": {
            "high": {
              "disabled": true
            },
            "max": {
              "disabled": true
            }
          }
        },
        "gpt-5.4": {
          "variants": {
            "none": {
              "disabled": true
            },
            "minimal": {
              "disabled": true
            },
            "low": {
              "disabled": true
            }
          }
        },
        "gpt-5.3-codex": {
          "variants": {
            "none": {
              "disabled": true
            },
            "minimal": {
              "disabled": true
            },
            "low": {
              "disabled": true
            },
            "medium": {
              "disabled": true
            },
            "high": {
              "disabled": true
            },
            "xhigh": {
              "disabled": true
            }
          }
        },
        "gemini-3-flash-preview": {
          "variants": {
            "low": {
              "disabled": true
            },
            "high": {
              "disabled": true
            }
          }
        },
        "gemini-3.1-pro-preview": {
          "variants": {
            "low": {
              "disabled": true
            }
          }
        },
        "gpt-4.1": {
          "disabled": true
        },
        "gpt-4o": {
          "disabled": true
        },
        "gpt-5-mini": {
          "disabled": true
        },
        "claude-opus-4.5": {
          "disabled": true
        },
        "claude-sonnet-4.5": {
          "disabled": true
        },
        "gpt-5.2": {
          "disabled": true
        },
        "gpt-5.2-codex": {
          "disabled": true
        },
        "claude-opus-4.7": {
          "variants": {
            "max": {
              "disabled": true
            }
          }
        }
      }
    }
  }
}
