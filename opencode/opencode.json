{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "prometheus",
  "permission": {
    "edit": "allow",
    "webfetch": "ask",
    "bash": {
      "*": "ask",

      "ls": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail": "allow",
      "tail -n*": "allow",
      "tail -n *": "allow",
      "wc *": "allow",
      "file *": "allow",
      "stat *": "allow",
      "grep *": "allow",
      "rg *": "allow",

      "pwd": "allow",
      "echo *": "allow",
      "which *": "allow",
      "type *": "allow",
      "command -v *": "allow",
      "whoami": "allow",
      "env": "allow",
      "printenv": "allow",
      "printenv *": "allow",
      "date": "allow",
      "date *": "allow",

      "eza *": "allow",
      "bat *": "allow",
      "fd *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "tree": "allow",
      "tree *": "allow",

      "sort *": "allow",
      "uniq *": "allow",
      "awk *": "allow",
      "sed -n *": "allow",
      "column *": "allow",
      "diff *": "allow",

      "ps": "allow",
      "ps *": "allow",
      "lsof": "allow",
      "lsof *": "allow",
      "df": "allow",
      "df *": "allow",
      "du *": "allow",
      "man *": "allow",

      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git branch": "allow",
      "git branch -v": "allow",
      "git branch -vv": "allow",
      "git branch -a": "allow",
      "git branch --list*": "allow",
      "git remote -v": "allow",
      "git remote show *": "allow",
      "git config --get *": "allow",
      "git config --list": "allow",
      "git config --list *": "allow",
      "git rev-parse *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git stash list": "allow",
      "git tag": "allow",
      "git tag -l*": "allow",
      "git tag --list*": "allow",
      "git describe": "allow",
      "git describe *": "allow",
      "git blame *": "allow",
      "git shortlog *": "allow",

      "brew list": "allow",
      "brew list *": "allow",
      "brew info *": "allow",
      "brew --version": "allow",
      "brew --prefix*": "allow",
      "npm list": "allow",
      "npm list *": "allow",
      "npm ls": "allow",
      "npm ls *": "allow",
      "pip list": "allow",
      "pip list *": "allow",
      "pip show *": "allow",
      "mise ls": "allow",
      "mise ls *": "allow",
      "mise list": "allow",
      "mise list *": "allow",
      "mise current": "allow",
      "mise current *": "allow"
    }
  },
  "lsp": {
    "typescript-language-server": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ]
    },
    "pyright": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "ruby-lsp": {
      "command": [
        "ruby-lsp"
      ],
      "extensions": [
        ".rb",
        ".rake",
        ".gemspec",
        ".ru"
      ]
    },
    "elixir-ls": {
      "command": [
        "elixir-ls"
      ],
      "extensions": [
        ".ex",
        ".exs",
        ".eex",
        ".heex",
        ".leex",
        ".sface"
      ]
    }
  },
  "plugin": [
    "oh-my-openagent@latest",
    "context-mode"
  ],
  "autoupdate": "notify",
  "share": "manual",
  "mcp": {
    "context-mode": {
      "type": "local",
      "command": [
        "context-mode"
      ]
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd"
      ],
      "environment": {}
    },
    "memory": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "environment": {
        "MEMORY_FILE_PATH": "/Users/zentetsuken/.config/opencode/memory.json"
      }
    }
  },
  "provider": {
    "github-copilot": {
      "models": {
        "claude-opus-4.6": {
          "variants": {
            "max": {
              "disabled": true
            }
          }
        },
        "claude-sonnet-4.6": {
          "variants": {
            "max": {
              "disabled": true
            }
          }
        },
        "claude-haiku-4.5": {
          "variants": {
            "high": {
              "disabled": true
            },
            "max": {
              "disabled": true
            }
          }
        },
        "gpt-5.4": {
          "variants": {
            "none": {
              "disabled": true
            },
            "minimal": {
              "disabled": true
            },
            "low": {
              "disabled": true
            }
          }
        },
        "gpt-5.3-codex": {
          "variants": {
            "none": {
              "disabled": true
            },
            "minimal": {
              "disabled": true
            },
            "low": {
              "disabled": true
            },
            "medium": {
              "disabled": true
            },
            "high": {
              "disabled": true
            },
            "xhigh": {
              "disabled": true
            }
          }
        },
        "gemini-3-flash-preview": {
          "variants": {
            "low": {
              "disabled": true
            },
            "high": {
              "disabled": true
            }
          }
        },
        "gemini-3.1-pro-preview": {
          "variants": {
            "low": {
              "disabled": true
            }
          }
        },
        "gpt-4.1": {
          "disabled": true
        },
        "gpt-4o": {
          "disabled": true
        },
        "gpt-5-mini": {
          "disabled": true
        },
        "claude-opus-4.5": {
          "disabled": true
        },
        "claude-sonnet-4.5": {
          "disabled": true
        },
        "gpt-5.2": {
          "disabled": true
        },
        "gpt-5.2-codex": {
          "disabled": true
        },
        "claude-opus-4.7": {
          "variants": {
            "max": {
              "disabled": true
            }
          }
        }
      }
    }
  }
}
