{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "prometheus",
  "enabled_providers": [
    "github-copilot",
    "opencode",
    "opencode-go",
    "openrouter",
    "minimax",
    "zai-coding-plan",
    "commandcode"
  ],
  "small_model": "github-copilot/claude-haiku-4.5",
  "instructions": [],
  "experimental": {
    "batch_tool": true,
    "continue_loop_on_deny": true
  },
  "permission": {
    "edit": "allow",
    "external_directory": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      "~/.password-store/**": "deny",
      "~/Library/Keychains/**": "deny",
      "~/.aws/credentials": "deny",
      "~/.kube/config": "ask",
      "~/.config/tmux/**": "allow",
      "~/.config/opencode/**": "allow",
      "~/.mnemosyne/**": "allow",
      "*": "ask"
    },
    "doom_loop": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "allow",
      "/.*\\|\\s*xargs(\\s|$).*/": "ask",
      "/.*\\b(bash|sh|zsh)\\s+-c\\b.*/": "ask",
      "rm *": "ask",
      "rmdir *": "ask",
      "unlink *": "ask",
      "sudo *": "ask",
      "doas *": "ask",
      "git push --force": "ask",
      "git push --force *": "ask",
      "git push -f": "ask",
      "git push -f *": "ask",
      "git push --force-with-lease": "ask",
      "git push --force-with-lease*": "ask",
      "git push --delete *": "ask",
      "git reset --hard": "ask",
      "git reset --hard *": "ask",
      "git rebase *": "ask",
      "git filter-branch *": "ask",
      "git filter-repo *": "ask",
      "git branch -d *": "ask",
      "git branch -D *": "ask",
      "git clean -f*": "ask",
      "git clean -d*": "ask",
      "git restore --staged *": "ask",
      "git checkout -- *": "ask",
      "git checkout .": "ask",
      "git stash drop": "ask",
      "git stash drop *": "ask",
      "git stash clear": "ask",
      "git tag -d *": "ask",
      "dd *": "ask",
      "mkfs*": "ask",
      "shutdown*": "ask",
      "reboot*": "ask",
      "halt*": "ask",
      "kill -9 *": "ask",
      "killall *": "ask",
      "brew uninstall *": "ask",
      "npm uninstall *": "ask",
      "pip uninstall *": "ask",
      "mise uninstall *": "ask"
    },
    "websearch": "ask"
  },
  "lsp": {
    "typescript-language-server": {
      "command": [
        "typescript-language-server",
        "--stdio"
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts"
      ]
    },
    "pyright": {
      "command": [
        "pyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "ruby-lsp": {
      "command": [
        "ruby-lsp"
      ],
      "extensions": [
        ".rb",
        ".rake",
        ".gemspec",
        ".ru"
      ]
    },
    "elixir-ls": {
      "command": [
        "elixir-ls"
      ],
      "extensions": [
        ".ex",
        ".exs",
        ".eex",
        ".heex",
        ".leex",
        ".sface"
      ]
    }
  },
  "plugin": [
    "oh-my-openagent@4.8.1",
    "context-mode"
  ],
  "autoupdate": false,
  "share": "manual",
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd"
      ],
      "environment": {}
    },
    "memory": {
      "type": "local",
      "command": [
        "sh",
        "-c",
        "exec env MEMORY_FILE_PATH=\"$HOME/.config/opencode/memory.json\" npx -y @modelcontextprotocol/server-memory"
      ],
      "environment": {}
    }
  },
  "provider": {
    "github-copilot": {},
    "opencode": {},
    "opencode-go": {},
    "openrouter": {}
  }
}
